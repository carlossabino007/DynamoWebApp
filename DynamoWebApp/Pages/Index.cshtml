@page
@model IndexModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="card shadow-lg">

    <div class="card-header bg-primary text-white">

        <h2>

            <i class="bi bi-camera-video-fill"></i>

            Top Youtubers

        </h2>

    </div>

    <div class="card-body">

        <form method="get">

            <div class="row">

                <div class="col-md-8">

                    <input asp-for="YoutuberFilter"
                           class="form-control form-control-lg"
                           placeholder="Buscar Youtuber..." />

                </div>

                <div class="col-md-2">

                    <button class="btn btn-success w-100">

                        <i class="bi bi-search"></i>

                        Buscar

                    </button>

                </div>

                <div class="col-md-2">

                    <a asp-page="/Index"
                       class="btn btn-secondary w-100">

                        Todos

                    </a>

                </div>

            </div>

        </form>

        <hr>

        <div class="alert alert-info">

            <b>Total registros:</b>

            @Model.Products.Count

        </div>

        <table class="table table-striped table-hover">

            <thead class="table-dark">

                <tr>

                    <th>#</th>

                    <th>Canal</th>

                    <th>Subscriptores</th>

                    <th>Views</th>

                    <th>Videos</th>

                    <th>Categoría</th>

                    <th>Inicio</th>

                </tr>

            </thead>

            <tbody>

                @foreach (var p in Model.Products)
                {
                    <tr>

                        <td>@p.Rank</td>

                        <td>

                            <strong>@p.Youtuber</strong>

                        </td>

                        <td>@p.Subscribers</td>

                        <td>@p.Video_views</td>

                        <td>@p.Video_count</td>

                        <td>

                            <span class="badge bg-primary">

                                @p.Category

                            </span>

                        </td>

                        <td>@p.Started</td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>